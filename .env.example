# Google Sheets API Credentials (2つの方法のいずれかを使用)
# 方法1: Base64エンコード形式（推奨）
# service-account.json ファイルを Base64 エンコードした文字列
GOOGLE_SHEETS_CREDENTIALS_B64=<your_base64_encoded_credentials_here>

# 方法2: JSON 文字列形式
# GOOGLE_SHEETS_CREDENTIALS_JSON={"type": "service_account", "project_id": "...", "private_key": "...", ...}

# Google Sheets ID
GOOGLE_SHEETS_ID=your_google_sheets_id_here

# Money Forward API Key (if needed)
MF_API_KEY=your_moneyforward_api_key_here
